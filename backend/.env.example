# Server
PORT=4000
NODE_ENV=production

# Database (Render PostgreSQL)
DB_HOST=your-db-host.render.com
DB_PORT=5432
DB_NAME=ezheyo_admin
DB_USER=ezheyo_admin_user
DB_PASSWORD=your_db_password_here
DB_SSL=true

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ShipHeyo API
SHIPHEYO_API_URL=https://api.shipheyo.com
SHIPHEYO_AUTH_KEY=your_shipheyo_auth_key_here
